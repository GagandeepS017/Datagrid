# Anthropic API key (required). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Production frontend origin(s) allowed by CORS, comma-separated.
# Leave empty for local dev (localhost is always allowed). In production set to
# your Vercel URL, e.g. https://datagrid.vercel.app
FRONTEND_ORIGIN=

# Optional public-demo request cap on expensive endpoints (query, profile, lab,
# upload). 0 or unset = unlimited. Set a positive number to protect API costs.
DEMO_MAX_REQUESTS=0
