# Backend API base URL.
# Leave empty for local development: requests use relative /api/* paths and Vite
# proxies them to the local backend (see vite.config.js).
# In production (Vercel), set this to your Render backend URL, e.g.
# VITE_API_BASE_URL=https://datagrid-backend.onrender.com
VITE_API_BASE_URL=
